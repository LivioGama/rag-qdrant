{
  "name": "rag-qdrant",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "dev-frontend": "turbo run dev --filter=frontend",
    "build": "turbo run build",
    "build-frontend": "turbo run build --filter=frontend",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "kill": "lsof -i tcp:3000 -t | xargs -r sudo kill",
    "format:packagejson": "bunx prettier-package-json --write ./package.json",
    "clean-all-node-modules": "bunx npkill",
    "ncu-u": "ncu -u --deep",
    "release-all-ports": "killall node",
    "reset": "rm -rf node_modules bun.lock && bun install",
    "setup:qdrant": "bun run scripts/setup-qdrant.js",
    "force-setup:qdrant": "bun run scripts/setup-qdrant.js --recreate",
    "run-qdrant": "docker run -p 6333:6333 -p 6334:6334 -v $(pwd)/qdrant_storage:/qdrant/storage:z qdrant/qdrant",
    "load-charge-test": "bun run scripts/load-charge-test.js apps/frontend/app/components",
    "setup-all": "bun run scripts/setup-all.js"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.21",
    "@qdrant/js-client-rest": "^1.14.0",
    "@tanstack/react-query": "^5.75.1",
    "@types/inquirer": "^9.0.8",
    "@types/uuid": "^10.0.0",
    "ai": "^4.3.13",
    "axios": "^1.9.0",
    "inquirer": "^12.6.1",
    "lodash": "^4.17.21",
    "next": "15.3.1",
    "prismjs": "^1.30.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.56.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/lodash": "^4.17.16",
    "@types/node": "^20",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.5.0",
    "eslint": "8.57.0",
    "eslint-config-next": "^13.4.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-only-warn": "^1.1.0",
    "eslint-plugin-prefer-arrow-functions": "^3.2.4",
    "eslint-plugin-react": "7.28.0",
    "eslint-plugin-turbo": "^2.5.2",
    "prettier": "^3.5.3",
    "tailwindcss": "^4",
    "turbo": "^2.5.2",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.31.1",
    "enquirer": "^2.4.1"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
